# =============================================================
#  Jansky — API Keys
# =============================================================
#  Copy this file to .env and fill in your keys.
#
#    cp .env.example .env
#
#  All keys are OPTIONAL. Jansky works without them, but you
#  lose the corresponding feature (see table below).
#
#  ┌────────────────────────┬────────────────────────────────┐
#  │ Variable               │ Feature unlocked               │
#  ├────────────────────────┼────────────────────────────────┤
#  │ OPENWEATHER_API_KEY    │ Live weather lookups           │
#  │ NEWSAPI_KEY            │ Top news headlines             │
#  │ GROQ_API_KEY           │ Cloud AI answers (Groq)        │
#  │ GROQ_MODEL             │ Optional Groq model id         │
#  │ MOONSHOT_API_KEY       │ (disabled) Kimi — see cloud_client.py │
#  │ SPOTIFY_CLIENT_ID      │ Voice: "play …" / "pause music" (Premium) │
#  │ SPOTIFY_CLIENT_SECRET  │ Run: python setup_spotify_token.py       │
#  │ SPOTIFY_REFRESH_TOKEN  │ Optional: SPOTIFY_DEVICE_ID              │
#  └────────────────────────┴────────────────────────────────┘
# =============================================================

OPENWEATHER_API_KEY=
NEWSAPI_KEY=
GROQ_API_KEY=
GROQ_MODEL=
MOONSHOT_API_KEY=

# Spotify (https://developer.spotify.com/dashboard — redirect http://127.0.0.1:8888/callback)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# Optional: target a specific speaker/phone app (python setup_spotify_token.py --list-devices)
SPOTIFY_DEVICE_ID=
